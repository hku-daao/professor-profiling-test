# Railway: add the same keys in the service → Variables tab (env files are not uploaded from git).
SUPABASE_URL=https://xxxx.supabase.co
# Project Settings → API → service_role (secret). Required for sync; anon key is not sufficient.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Optional alias for the same secret: SUPABASE_SERVICE_KEY=
HKU_HUB_BASE=https://hub.hku.hk
# Full sync fetches each publication’s /handle/… page to read Abstract (one HTTP call per item).
# Each grant row also fetches /cris/project/… for full Grant Data (set false to skip; faster sync).
FETCH_GRANT_DETAILS=true
REQUEST_DELAY_SEC=0.35
HTTP_TIMEOUT=60
RPP=100
MAX_PROFESSORS=0
